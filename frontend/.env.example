# Frontend Environment Configuration
# Copy this file to .env.local and update with your values

# =====================================================
# API CONFIGURATION
# =====================================================
# Backend API base URL - ensure this matches your backend server
VITE_API_URL=http://localhost:8080/api

# =====================================================
# SUPABASE CONFIGURATION (Optional)
# =====================================================
# Get these from your Supabase project settings
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# =====================================================
# PAYMENT GATEWAY (Razorpay)
# =====================================================
# Get your key from Razorpay dashboard
VITE_RAZORPAY_KEY_ID=rzp_test_<your-key>

# =====================================================
# GOOGLE MAPS API (Optional)
# =====================================================
# Required for map features in the application
VITE_GOOGLE_MAPS_API_KEY=<your-api-key>

# =====================================================
# APPLICATION CONFIGURATION
# =====================================================
VITE_APP_NAME=Namma Market
VITE_APP_VERSION=1.0.0
