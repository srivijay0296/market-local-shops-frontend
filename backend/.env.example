# Backend Environment Configuration
# Copy this file to .env.local and update with your values

# =====================================================
# DATABASE CONFIGURATION
# =====================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/namma_market
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=Vijayraj143@
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# =====================================================
# JPA/HIBERNATE CONFIGURATION
# =====================================================
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_USE_SQL_COMMENTS=true

# =====================================================
# SERVER CONFIGURATION
# =====================================================
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api
SERVER_SERVLET_ENCODING_CHARSET=UTF-8

# =====================================================
# JWT CONFIGURATION
# =====================================================
# Generate a secure JWT secret (minimum 32 characters)
# Use: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long
JWT_EXPIRATION_MS=86400000

# =====================================================
# CORS CONFIGURATION
# =====================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# =====================================================
# LOGGING CONFIGURATION
# =====================================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_MARKETLOCALSHOPS=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=DEBUG

# =====================================================
# APPLICATION CONFIGURATION
# =====================================================
SPRING_APPLICATION_NAME=Namma Market Backend
SPRING_PROFILES_ACTIVE=dev

# =====================================================
# ACTUATOR CONFIGURATION (Monitoring)
# =====================================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized
